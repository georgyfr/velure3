{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "base", "color": "#FAFAF8", "name": "Base" },
        { "slug": "contrast", "color": "#1A1A1A", "name": "Contrast" },
        { "slug": "primary", "color": "#1A1A1A", "name": "Primary" },
        { "slug": "secondary", "color": "#C8A97E", "name": "Secondary / Gold" },
        { "slug": "accent", "color": "#8B5E3C", "name": "Accent / Cognac" },
        { "slug": "muted", "color": "#E8E4DE", "name": "Muted" },
        { "slug": "soft", "color": "#F5F0EB", "name": "Soft Cream" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ]
    },
    "typography": {
      "fontFamilies": [
        { "fontFamily": "'Inter', sans-serif", "name": "Inter", "slug": "inter" },
        { "fontFamily": "'Playfair Display', serif", "name": "Playfair Display", "slug": "playfair-display" },
        { "fontFamily": "'Cormorant Garamond', serif", "name": "Cormorant Garamond", "slug": "cormorant" }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.75rem", "name": "Extra Large" },
        { "slug": "xx-large", "size": "2.5rem", "name": "Huge" },
        { "slug": "hero", "size": "clamp(3rem, 8vw, 7rem)", "name": "Hero" }
      ]
    },
    "spacing": {
      "units": [ "px", "rem", "em", "%", "vw", "vh" ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "custom": {
      "headerHeight": "80px",
      "footerTop": "2rem",
      "radius": "0px",
      "transition": "0.3s cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.7"
    },
    "spacing": {
      "padding": {
        "top": "0",
        "right": "1.5rem",
        "bottom": "0",
        "left": "1.5rem"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      },
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair-display)",
          "fontWeight": "500",
          "lineHeight": "1.2"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--contrast)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": {
          "radius": "0px"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "0.75rem",
          "letterSpacing": "0.15em",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "blank", "title": "Blank", "postTypes": [ "page", "post" ] }
  ]
}